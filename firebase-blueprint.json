{
  "entities": {
    "Identity": {
      "title": "Identity Node",
      "description": "Represents a secure unique 11-character passcode node.",
      "type": "object",
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this identity node was first registered online."
        }
      },
      "required": ["createdAt"]
    },
    "Session": {
      "title": "Chat Session",
      "description": "A modular chat session with multi-model historical logs.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique session string identifier."
        },
        "name": {
          "type": "string",
          "description": "Human-readable workspace label description."
        },
        "timestamp": {
          "type": "string",
          "description": "Readable localized updated date timestamp."
        },
        "histories": {
          "type": "object",
          "description": "Model-specific history message map records."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server matching updated timestamp."
        }
      },
      "required": ["id", "name", "timestamp", "histories", "updatedAt"]
    }
  },
  "firestore": {
    "/identities/{identityId}": {
      "schema": "Identity",
      "description": "Global user identity entries."
    },
    "/identities/{identityId}/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Modular chat session collections owned by this specific identity passcode."
    }
  }
}
